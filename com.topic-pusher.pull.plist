<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.topic-pusher.pull</string>

    <key>Program</key>
    <string>/Users/thousee/topic-pusher/pull.sh</string>

    <!-- 开机/唤醒时运行 -->
    <key>RunAtLoad</key>
    <true/>

    <!-- 每天早上 8:15 运行（GitHub Action 8:00 跑完） -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>15</integer>
    </dict>

    <!-- 每 2 小时兜底 -->
    <key>StartInterval</key>
    <integer>7200</integer>

    <key>StandardOutPath</key>
    <string>/Users/thousee/Library/Logs/topic-pusher.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/thousee/Library/Logs/topic-pusher.log</string>
</dict>
</plist>
